# ── Переменные окружения дашборда «Пульс доставки» ──────────────────────────────
# Скопируй в .env (локально) или задай как секреты в окружении (HF Space / CI / прод).
# .env в .gitignore — реальные значения в репозиторий не попадают.

# Яндекс.Трекер
TRACKER_TOKEN=            # OAuth-токен Трекера (обязательно для синка/записи)
ORG_ID=7405124           # X-Org-ID (id организации в Трекере)

# Turso (SQLite по HTTP) — хранилище снапшотов/истории
TURSO_URL=               # libsql://<db>.turso.io  (код сам заменит на https://)
TURSO_TOKEN=             # auth-токен Turso

# AI (нужен хотя бы один; без них AI-функции просто отключаются)
CLAUDE_TOKEN=            # ключ Anthropic (или ANTHROPIC_API_KEY)
CLAUDE_MODEL=claude-sonnet-4-20250514
MISTRAL_TOKEN=           # ключ Mistral (fallback; или MISTRAL_API_KEY)
MISTRAL_MODEL=mistral-small-latest

# WIP-лимиты «Поток E2E» (необязательно, есть дефолты)
WIP_DISCOVERY=25
WIP_DELIVERY=20
FLOW_TARGET=60           # целевой WIP Age (красная линия)
